<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>From My Heart To Yours 💕</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --deep-rose: #c0215a;
      --rose: #e63c7e;
      --pink: #ff6fa8;
      --light-pink: #ffb3cf;
      --blush: #ffe4ef;
      --cream: #fff5f9;
      --white: #ffffff;
      --gold: #f7c59f;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Lato', sans-serif;
      background: #1a0010;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      overflow: hidden;
    }

    /* ─── Floating Hearts BG Layer ─── */
    #hearts-bg {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .bg-heart {
      position: absolute;
      bottom: -80px;
      font-size: 1.5rem;
      opacity: 0;
      animation: floatUp linear infinite;
      user-select: none;
    }

    @keyframes floatUp {
      0%   { transform: translateY(0) rotate(0deg) scale(0.8); opacity: 0; }
      10%  { opacity: 0.6; }
      90%  { opacity: 0.3; }
      100% { transform: translateY(-110vh) rotate(360deg) scale(1.2); opacity: 0; }
    }

    /* ─── Slide Wrapper ─── */
    #slideshow {
      position: relative;
      z-index: 10;
      width: min(860px, 96vw);
      aspect-ratio: 16/9;
    }

    .slide {
      display: none;
      width: 100%;
      height: 100%;
      border-radius: 24px;
      overflow: hidden;
      position: relative;
      animation: slideIn 0.7s cubic-bezier(0.22,1,0.36,1);
    }

    .slide.active { display: flex; }

    @keyframes slideIn {
      from { opacity: 0; transform: scale(0.93) translateY(20px); }
      to   { opacity: 1; transform: scale(1)    translateY(0); }
    }

    /* ─── Shared slide structure ─── */
    .slide-inner {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 5%;
      gap: 18px;
    }

    /* ─── Decorative hearts inside slides ─── */
    .deco-heart {
      position: absolute;
      font-size: 1.2rem;
      opacity: 0.15;
      animation: pulse 2.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 0.12; }
      50%       { transform: scale(1.3); opacity: 0.25; }
    }

    /* ─── Typography ─── */
    .slide-tag {
      font-family: 'Lato', sans-serif;
      font-size: clamp(10px, 1.4vw, 14px);
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--light-pink);
      opacity: 0.85;
    }

    .slide-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(22px, 4.5vw, 48px);
      line-height: 1.15;
      color: var(--white);
      text-shadow: 0 2px 30px rgba(230,60,126,0.5);
    }

    .slide-title em { color: var(--pink); font-style: italic; }

    .slide-body {
      font-family: 'Lato', sans-serif;
      font-size: clamp(12px, 2vw, 20px);
      font-weight: 300;
      line-height: 1.7;
      color: var(--blush);
      max-width: 80%;
    }

    .slide-body strong { color: var(--pink); font-weight: 700; }

    .heart-divider {
      font-size: 1.8rem;
      letter-spacing: 10px;
      animation: pulse 1.8s ease-in-out infinite;
    }

    /* ─── SLIDE 1 – Cover ─── */
    #s1 { background: radial-gradient(ellipse at 50% 60%, #6b0040 0%, #2a0022 60%, #100008 100%); }
    #s1 .main-heart {
      font-size: clamp(60px, 12vw, 120px);
      animation: heartbeat 1.4s ease-in-out infinite;
      filter: drop-shadow(0 0 30px #ff6fa8);
    }
    @keyframes heartbeat {
      0%,100% { transform: scale(1); }
      14%      { transform: scale(1.15); }
      28%      { transform: scale(1); }
      42%      { transform: scale(1.1); }
      70%      { transform: scale(1); }
    }

    /* ─── SLIDE 2 – Why I'm Sorry ─── */
    #s2 { background: linear-gradient(135deg, #4a0030 0%, #1e0018 50%, #3b0028 100%); }

    /* ─── SLIDE 3 – You Mean Everything ─── */
    #s3 { background: radial-gradient(ellipse at 30% 40%, #5c002a 0%, #1a0012 100%); }
    .orbit-container {
      position: relative;
      width: clamp(140px, 25vw, 220px);
      height: clamp(140px, 25vw, 220px);
    }
    .orbit-center {
      position: absolute;
      inset: 50%;
      transform: translate(-50%,-50%);
      font-size: clamp(36px, 6vw, 60px);
      filter: drop-shadow(0 0 20px #ff6fa8);
    }
    .orbit-planet {
      position: absolute;
      font-size: clamp(16px, 2.5vw, 26px);
      animation: orbit linear infinite;
      transform-origin: center center;
    }
    @keyframes orbit {
      from { transform: rotate(var(--start)) translateX(var(--r)) rotate(calc(-1 * var(--start))); }
      to   { transform: rotate(calc(var(--start) + 360deg)) translateX(var(--r)) rotate(calc(-1 * (var(--start) + 360deg))); }
    }

    /* ─── SLIDE 4 – My Mistakes ─── */
    #s4 { background: linear-gradient(160deg, #380020 0%, #150010 60%, #420028 100%); }
    .sorry-list {
      list-style: none;
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .sorry-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: clamp(11px, 1.8vw, 17px);
      color: var(--blush);
    }
    .sorry-list li span { color: var(--pink); font-size: 1.1em; }

    /* ─── SLIDE 5 – What I Love About You ─── */
    #s5 { background: radial-gradient(ellipse at 70% 30%, #5e0035 0%, #1c0015 100%); }
    .love-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      max-width: 85%;
    }
    .pill {
      background: rgba(255, 111, 168, 0.15);
      border: 1px solid rgba(255,111,168,0.4);
      border-radius: 999px;
      padding: 6px 18px;
      font-size: clamp(10px, 1.5vw, 15px);
      color: var(--light-pink);
      backdrop-filter: blur(4px);
      animation: popIn 0.5s cubic-bezier(0.22,1,0.36,1) both;
    }
    @keyframes popIn {
      from { transform: scale(0); opacity: 0; }
      to   { transform: scale(1); opacity: 1; }
    }

    /* ─── SLIDE 6 – Promise ─── */
    #s6 { background: linear-gradient(200deg, #420025 0%, #200018 50%, #380025 100%); }
    .promise-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,111,168,0.3);
      border-radius: 18px;
      padding: 24px 32px;
      max-width: 80%;
      backdrop-filter: blur(10px);
    }
    .promise-card p {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(12px, 1.9vw, 19px);
      color: var(--blush);
      line-height: 1.8;
    }

    /* ─── SLIDE 7 – Photo Gallery ─── */
    #s7 { background: radial-gradient(ellipse at 50% 80%, #5a0032 0%, #1a0010 100%); }

    /* Photo upload button */
    #photo-upload-btn {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 100;
      background: linear-gradient(135deg, var(--rose), var(--deep-rose));
      color: white;
      border: none;
      border-radius: 999px;
      padding: 12px 22px;
      font-size: 14px;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(230,60,126,0.5);
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s ease;
      letter-spacing: 0.5px;
    }
    #photo-upload-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(230,60,126,0.65);
    }
    #photo-upload-input { display: none; }

    /* Polaroid grid */
    .photo-grid {
      display: flex;
      gap: clamp(8px, 2vw, 18px);
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      max-width: 90%;
      max-height: 58%;
      overflow: hidden;
    }
    .polaroid {
      background: #fff;
      padding: clamp(4px, 0.8vw, 8px) clamp(4px, 0.8vw, 8px) clamp(14px, 2.5vw, 26px);
      box-shadow: 0 6px 25px rgba(0,0,0,0.45);
      border-radius: 2px;
      display: inline-block;
      transform: rotate(var(--tilt, 0deg));
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      animation: popIn 0.5s cubic-bezier(0.22,1,0.36,1) both;
    }
    .polaroid:hover {
      transform: rotate(0deg) scale(1.06);
      box-shadow: 0 12px 40px rgba(230,60,126,0.5);
      z-index: 5;
    }
    .polaroid img {
      display: block;
      width: clamp(70px, 12vw, 130px);
      height: clamp(70px, 12vw, 130px);
      object-fit: cover;
    }
    .polaroid .photo-caption {
      text-align: center;
      font-family: 'Playfair Display', serif;
      font-style: italic;
      color: #c0215a;
      font-size: clamp(7px, 1.1vw, 11px);
      margin-top: clamp(3px, 0.5vw, 6px);
    }

    /* Empty state */
    .photo-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      color: rgba(255,179,207,0.5);
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(13px, 2vw, 20px);
    }
    .photo-empty .empty-icon { font-size: clamp(36px, 6vw, 60px); opacity: 0.4; }

    /* ─── SLIDE 8 – Memories ─── */
    #s8mem { background: radial-gradient(ellipse at 50% 80%, #5a0032 0%, #1a0010 100%); }
    .memory-dots {
      display: flex;
      gap: 14px;
      align-items: center;
    }
    .memory-dot {
      width: clamp(60px, 10vw, 90px);
      height: clamp(60px, 10vw, 90px);
      border-radius: 50%;
      background: rgba(255,111,168,0.12);
      border: 2px solid rgba(255,111,168,0.35);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: clamp(18px, 3vw, 30px);
      gap: 2px;
      animation: glow 2s ease-in-out infinite;
    }
    .memory-dot small {
      font-size: clamp(7px, 1vw, 10px);
      color: var(--light-pink);
      font-family: 'Lato', sans-serif;
    }
    @keyframes glow {
      0%,100% { box-shadow: 0 0 0px rgba(255,111,168,0); }
      50%      { box-shadow: 0 0 20px rgba(255,111,168,0.5); }
    }

    /* ─── SLIDE 8 – I Need You ─── */
    #s8 { background: linear-gradient(150deg, #3e001e 0%, #180010 60%, #440026 100%); }
    .need-you-text {
      font-family: 'Playfair Display', serif;
      font-size: clamp(13px, 2.4vw, 26px);
      color: var(--blush);
      line-height: 1.8;
      max-width: 78%;
      font-style: italic;
    }

    /* ─── SLIDE 9 – Please Forgive Me ─── */
    #s9 { background: radial-gradient(ellipse at 40% 50%, #5c0030 0%, #1e0015 100%); }
    .forgive-heart {
      font-size: clamp(50px, 9vw, 90px);
      animation: shatter 3s ease-in-out infinite;
      filter: drop-shadow(0 0 20px #e63c7e);
    }
    @keyframes shatter {
      0%,100% { transform: scale(1) rotate(0deg); filter: drop-shadow(0 0 15px #e63c7e); }
      25%      { transform: scale(0.9) rotate(-5deg); filter: drop-shadow(0 0 5px #e63c7e); }
      50%      { transform: scale(1.1) rotate(5deg); filter: drop-shadow(0 0 35px #ff6fa8); }
      75%      { transform: scale(0.95) rotate(-3deg); filter: drop-shadow(0 0 10px #e63c7e); }
    }

    /* ─── SLIDE 10 – Cover Finale ─── */
    #s10 { background: radial-gradient(ellipse at 50% 50%, #7a0048 0%, #2e0020 55%, #0e0008 100%); }
    .finale-hearts {
      display: flex;
      gap: 12px;
      font-size: clamp(22px, 4vw, 40px);
      animation: heartbeat 1.4s ease-in-out infinite;
    }
    .finale-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(14px, 2.5vw, 28px);
      color: var(--gold);
      letter-spacing: 4px;
    }
    .glitter-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(28px, 5.5vw, 58px);
      background: linear-gradient(90deg, #ff6fa8, #ffb3cf, #e63c7e, #ff6fa8);
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s linear infinite;
    }
    @keyframes shimmer {
      from { background-position: 0% center; }
      to   { background-position: 200% center; }
    }

    /* ─── Navigation ─── */
    #nav {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 20px;
      margin-top: 24px;
    }

    .nav-btn {
      background: rgba(255,111,168,0.15);
      border: 1px solid rgba(255,111,168,0.4);
      border-radius: 999px;
      padding: 10px 28px;
      font-size: 14px;
      color: var(--light-pink);
      cursor: pointer;
      transition: all 0.3s ease;
      font-family: 'Lato', sans-serif;
      letter-spacing: 1px;
    }
    .nav-btn:hover {
      background: rgba(255,111,168,0.35);
      box-shadow: 0 0 20px rgba(255,111,168,0.3);
    }
    .nav-btn:disabled {
      opacity: 0.3;
      cursor: default;
    }

    #slide-counter {
      color: rgba(255,179,207,0.6);
      font-size: 13px;
      letter-spacing: 2px;
      min-width: 70px;
      text-align: center;
    }

    /* ─── Progress dots ─── */
    #dots {
      position: relative;
      z-index: 10;
      display: flex;
      gap: 8px;
      margin-top: 14px;
    }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,111,168,0.25);
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .dot.active {
      background: var(--pink);
      transform: scale(1.4);
      box-shadow: 0 0 8px var(--pink);
    }
  </style>
</head>
<body>

<!-- Floating background hearts -->
<div id="hearts-bg"></div>

<!-- Slideshow -->
<div id="slideshow">

  <!-- SLIDE 1: Cover -->
  <div class="slide active" id="s1">
    <div class="slide-inner">
      <!-- Deco hearts -->
      <span class="deco-heart" style="top:8%;left:8%">💗</span>
      <span class="deco-heart" style="top:12%;right:10%">💕</span>
      <span class="deco-heart" style="bottom:12%;left:12%">💖</span>
      <span class="deco-heart" style="bottom:8%;right:8%">💓</span>

      <div class="main-heart">❤️</div>
      <div class="slide-tag">A message from my heart</div>
      <h1 class="slide-title">To The One Who<br /><em>Owns My Heart</em></h1>
      <div class="slide-body">
        This is for you. Every word, every heartbeat. 
        Please read till the very last slide. 💕
      </div>
    </div>
  </div>

  <!-- SLIDE 2: Why I'm Sorry -->
  <div class="slide" id="s2">
    <div class="slide-inner">
      <span class="deco-heart" style="top:10%;left:6%">💔</span>
      <span class="deco-heart" style="bottom:15%;right:6%">💗</span>

      <div class="slide-tag">I owe you this</div>
      <h2 class="slide-title">I Am So, So<br /><em>Sorry</em></h2>
      <div class="heart-divider">💕 💕 💕</div>
      <div class="slide-body">
        I know I hurt you. I know my actions didn't match
        everything I feel for you. And I am <strong>deeply, truly sorry</strong>
        from the very bottom of my heart.
        <br /><br />
        You deserve so much better — and I want to be that better.
      </div>
    </div>
  </div>

  <!-- SLIDE 3: You Mean Everything -->
  <div class="slide" id="s3">
    <div class="slide-inner">
      <span class="deco-heart" style="top:6%;right:8%">💖</span>
      <span class="deco-heart" style="bottom:10%;left:6%">✨</span>

      <div class="slide-tag">You are my universe</div>
      <h2 class="slide-title">You Mean <em>Everything</em><br />To Me</h2>

      <div class="orbit-container">
        <div class="orbit-center">❤️</div>
        <span class="orbit-planet" style="--start:0deg;  --r:90px; animation-duration:6s">⭐</span>
        <span class="orbit-planet" style="--start:90deg; --r:90px; animation-duration:6s">💫</span>
        <span class="orbit-planet" style="--start:180deg;--r:90px; animation-duration:6s">✨</span>
        <span class="orbit-planet" style="--start:270deg;--r:90px; animation-duration:6s">🌸</span>
      </div>

      <div class="slide-body">
        Before you, life was just ordinary. You made it
        <strong>magical</strong>. You are my calm in the chaos, my smile
        on the hardest days, my reason to be better.
      </div>
    </div>
  </div>

  <!-- SLIDE 4: My Mistakes -->
  <div class="slide" id="s4">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;left:8%">💔</span>
      <span class="deco-heart" style="bottom:10%;right:8%">💗</span>

      <div class="slide-tag">Facing the truth</div>
      <h2 class="slide-title">I Was <em>Wrong</em></h2>
      <div class="heart-divider">💕</div>

      <ul class="sorry-list">
        <li><span>💔</span> I should have listened more and argued less.</li>
        <li><span>💔</span> I should have put your feelings first, always.</li>
        <li><span>💔</span> I should have been more patient with you.</li>
        <li><span>💔</span> I let my pride get in the way of love.</li>
        <li><span>💔</span> I made you feel like you weren't enough — you are MORE than enough.</li>
      </ul>
    </div>
  </div>

  <!-- SLIDE 5: What I Love About You -->
  <div class="slide" id="s5">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;right:10%">💖</span>
      <span class="deco-heart" style="bottom:10%;left:8%">🌸</span>

      <div class="slide-tag">Why I adore you</div>
      <h2 class="slide-title">Things I <em>Love</em><br />About You</h2>

      <div class="love-pills">
        <div class="pill" style="animation-delay:0.0s">💗 Your laugh</div>
        <div class="pill" style="animation-delay:0.1s">💗 Your kindness</div>
        <div class="pill" style="animation-delay:0.2s">💗 The way you care</div>
        <div class="pill" style="animation-delay:0.3s">💗 Your strength</div>
        <div class="pill" style="animation-delay:0.4s">💗 Your eyes</div>
        <div class="pill" style="animation-delay:0.5s">💗 How you see the world</div>
        <div class="pill" style="animation-delay:0.6s">💗 Your voice</div>
        <div class="pill" style="animation-delay:0.7s">💗 Your silliness</div>
        <div class="pill" style="animation-delay:0.8s">💗 The way you love</div>
        <div class="pill" style="animation-delay:0.9s">💗 All of you</div>
      </div>
    </div>
  </div>

  <!-- SLIDE 6: Promise -->
  <div class="slide" id="s6">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;left:6%">💍</span>
      <span class="deco-heart" style="bottom:10%;right:6%">💖</span>

      <div class="slide-tag">My solemn vow</div>
      <h2 class="slide-title">I <em>Promise</em> You</h2>
      <div class="heart-divider">💕 💕 💕</div>

      <div class="promise-card">
        <p>
          "I promise to choose you, every single day. To listen before I speak.
          To hold your feelings gently. To be the partner you deserve — patient,
          present, and endlessly in love with you.
          <br /><br />
          I promise that the hurt stops here. And the love only grows deeper." 💕
        </p>
      </div>
    </div>
  </div>

  <!-- SLIDE 7: Our Photos (Gallery) -->
  <div class="slide" id="s7">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;right:8%">📸</span>
      <span class="deco-heart" style="bottom:10%;left:6%">💗</span>

      <div class="slide-tag">Us, captured forever</div>
      <h2 class="slide-title">Our <em>Photos</em></h2>

      <!-- Photo grid rendered by JS -->
      <div class="photo-grid" id="photo-grid">
        <div class="photo-empty" id="photo-empty">
          <span class="empty-icon">📷</span>
          <span>Click the pink button below to add your favourite photos 💕</span>
        </div>
      </div>
    </div>
  </div>

  <!-- SLIDE 8: Memories -->
  <div class="slide" id="s8mem">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;right:8%">🎞️</span>
      <span class="deco-heart" style="bottom:10%;left:6%">💗</span>

      <div class="slide-tag">Our story</div>
      <h2 class="slide-title">Every <em>Moment</em><br />We've Shared</h2>

      <div class="memory-dots">
        <div class="memory-dot">🌅<small>Our First Day</small></div>
        <div class="memory-dot">😂<small>Us Laughing</small></div>
        <div class="memory-dot">🤝<small>Us Together</small></div>
        <div class="memory-dot">🎆<small>Our Future</small></div>
      </div>

      <div class="slide-body">
        Every single memory with you is <strong>precious</strong>.
        I don't want to lose any more of them.
        I want to create a thousand more with you.
      </div>
    </div>
  </div>

  <!-- SLIDE 9: I Need You -->
  <div class="slide" id="s9need">
    <div class="slide-inner">
      <span class="deco-heart" style="top:10%;left:6%">🫂</span>
      <span class="deco-heart" style="bottom:8%;right:8%">💗</span>

      <div class="slide-tag">From the depths of my soul</div>
      <h2 class="slide-title">I <em>Need</em> You</h2>
      <div class="heart-divider">❤️</div>

      <p class="need-you-text">
        "Without you, the world feels dim. You are the person I think of first
        in the morning, and last at night. The one whose name lives permanently
        in my heartbeat.
        <br /><br />
        Please don't give up on us. I haven't. I never will."
      </p>
    </div>
  </div>

  <!-- SLIDE 10: Please Forgive Me -->
  <div class="slide" id="s10forg">
    <div class="slide-inner">
      <span class="deco-heart" style="top:8%;left:8%">💔</span>
      <span class="deco-heart" style="bottom:10%;right:8%">💗</span>

      <div class="slide-tag">My sincerest plea</div>
      <h2 class="slide-title">Please <em>Forgive</em> Me</h2>

      <div class="forgive-heart">💔➡️❤️</div>

      <div class="slide-body">
        I am not asking you to forget. I am asking you to
        <strong>give me the chance</strong> to earn your trust back —
        one day at a time, one promise at a time,
        one act of love at a time.
        <br /><br />
        You are worth every effort I have. 💕
      </div>
    </div>
  </div>

  <!-- SLIDE 10: Finale -->
  <div class="slide" id="s10">
    <div class="slide-inner">
      <span class="deco-heart" style="top:6%;left:6%">💖</span>
      <span class="deco-heart" style="top:6%;right:6%">💖</span>
      <span class="deco-heart" style="bottom:8%;left:6%">💖</span>
      <span class="deco-heart" style="bottom:8%;right:6%">💖</span>

      <div class="finale-hearts">💗 💕 ❤️ 💕 💗</div>
      <div class="glitter-title">I Love You</div>
      <div class="finale-name">Always &amp; Forever</div>
      <div class="heart-divider">💓 💓 💓</div>

      <div class="slide-body">
        No matter what happens, <strong>my love for you is forever</strong>.
        You are my person. My home. My heart.
        <br /><br />
        Thank you for reading this. I hope you feel every word. 💕
      </div>

      <div class="finale-hearts" style="font-size: clamp(16px,2.5vw,24px)">
        ❤️ 💕 💗 💕 ❤️
      </div>
    </div>
  </div>

</div>

<!-- Photo upload (floating) -->
<input type="file" id="photo-upload-input" accept="image/*" multiple />
<button id="photo-upload-btn" onclick="document.getElementById('photo-upload-input').click()">
  📷 Add Your Photos
</button>

<!-- Navigation -->
<div id="nav">
  <button class="nav-btn" id="prevBtn" onclick="changeSlide(-1)" disabled>← Prev</button>
  <span id="slide-counter">1 / 11</span>
  <button class="nav-btn" id="nextBtn" onclick="changeSlide(1)">Next →</button>
</div>

<!-- Dots -->
<div id="dots"></div>

<script>
  // ─── Slide logic ───
  const slides = document.querySelectorAll('.slide');
  const total = slides.length;
  let current = 0;

  const dotsContainer = document.getElementById('dots');
  const dotEls = [];
  for (let i = 0; i < total; i++) {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goTo(i);
    dotsContainer.appendChild(d);
    dotEls.push(d);
  }

  function goTo(idx) {
    slides[current].classList.remove('active');
    dotEls[current].classList.remove('active');
    current = idx;
    slides[current].classList.add('active');
    dotEls[current].classList.add('active');
    document.getElementById('slide-counter').textContent = `${current + 1} / ${total}`;
    document.getElementById('prevBtn').disabled = current === 0;
    document.getElementById('nextBtn').disabled = current === total - 1;
  }

  function changeSlide(dir) { goTo(current + dir); }

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' && current < total - 1) changeSlide(1);
    if (e.key === 'ArrowLeft'  && current > 0)         changeSlide(-1);
  });

  // ─── Photo Upload ───
  const captions = ['Us 💕','My fav 💖','Our moment 🌸','Forever ❤️','I love this 💗','My heart 💓','Us 💝','Always 💕'];
  const tilts    = [-4, 3, -2.5, 5, -3.5, 2, -5, 4];
  let photoCount = 0;

  document.getElementById('photo-upload-input').addEventListener('change', function(e) {
    const files = Array.from(e.target.files);
    if (!files.length) return;

    const grid  = document.getElementById('photo-grid');
    const empty = document.getElementById('photo-empty');
    if (empty) empty.remove();

    files.forEach((file, i) => {
      const reader = new FileReader();
      reader.onload = ev => {
        const idx  = (photoCount++) % tilts.length;
        const wrap = document.createElement('div');
        wrap.className = 'polaroid';
        wrap.style.setProperty('--tilt', tilts[idx] + 'deg');
        wrap.style.animationDelay = (i * 0.08) + 's';

        const img = document.createElement('img');
        img.src = ev.target.result;

        const cap = document.createElement('div');
        cap.className = 'photo-caption';
        cap.textContent = captions[idx];

        wrap.appendChild(img);
        wrap.appendChild(cap);
        grid.appendChild(wrap);
      };
      reader.readAsDataURL(file);
    });

    // reset input so same files can be re-added
    this.value = '';
  });

  // ─── Floating hearts background ───
  const bgContainer = document.getElementById('hearts-bg');
  const heartEmojis = ['💗','💕','💖','❤️','💓','💘','🌸','✨','💝'];
  const maxHearts = 28;

  function spawnHeart() {
    if (bgContainer.children.length >= maxHearts) return;
    const el = document.createElement('span');
    el.className = 'bg-heart';
    el.textContent = heartEmojis[Math.floor(Math.random() * heartEmojis.length)];
    const size = 1 + Math.random() * 1.8;
    el.style.fontSize = size + 'rem';
    el.style.left = Math.random() * 100 + '%';
    const dur = 6 + Math.random() * 10;
    el.style.animationDuration = dur + 's';
    el.style.animationDelay = (Math.random() * 3) + 's';
    bgContainer.appendChild(el);
    setTimeout(() => el.remove(), (dur + 3) * 1000);
  }

  setInterval(spawnHeart, 400);
  for (let i = 0; i < 12; i++) spawnHeart();
</script>
</body>
</html>
